# managed-skill-hub root environment example
# Copy to .env and edit non-secret configuration only. Copy
# .env.secrets.example to .env.secrets for credentials and keys.
#
# Authentication profiles:
# - .env.example.simple is the local/simple profile.
# - .env.example.authentik is the OIDC staging profile and requires the
#   environment-specific Authentik cutover gate before production activation.

# In local dev mode:
# - DATA_DIR is ./data relative to repository root.
# - API/Frontend are served on localhost:3040 / localhost:3041.
# For production, prefer absolute paths.
NODE_ENV=development
DATA_DIR=./data

## API
API_HOST=127.0.0.1
API_PORT=3040
# Comma-separated proxy IPs/CIDRs whose forwarded client IP headers are trusted.
# Keep empty for direct API access. For local nginx, use 127.0.0.1,::1.
API_TRUSTED_PROXIES=
REGISTRY_ID=local
REGISTRY_NAME="ManagedSkillHub Local"
PUBLIC_API_BASE_URL=http://localhost:3040
# Optional API prefix in single-host deployments, e.g. /api.
API_PREFIX=
# Comma-separated browser origins allowed to call the API with credentials.
CORS_ALLOWED_ORIGINS=http://localhost:3041,http://127.0.0.1:3041

## Admin
ADMIN_AUTH_MODE=simple
ADMIN_USER=admin
# ADMIN_PASSWORD, ADMIN_PASSWORD_HASH, and JWT_SECRET belong in .env.secrets.
SESSION_TTL_SECONDS=86400
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=300000
ADMIN_LOGIN_RATE_LIMIT_MAX_REQUESTS=10
ADMIN_LOGIN_RATE_LIMIT_MAX_BUCKETS=10000
# Checks Origin/Referer for authenticated admin mutations when present.
ADMIN_CSRF_ORIGIN_CHECK=true
ADMIN_UI_BASE_PATH=/frontend/admin

## Agent API auth
# Supported modes per area: none, bearer, oidc. Defaults keep local development open.
PUBLIC_READ_AUTH_MODE=none
PUBLIC_READ_BEARER_ACTOR=agent-read-token
PROPOSAL_AUTH_MODE=none
PROPOSAL_BEARER_ACTOR=agent-proposal-token
# Production requires PROPOSAL_AUTH_MODE=bearer unless this is explicitly true.
ALLOW_OPEN_PROPOSALS_IN_PRODUCTION=false
DISCOVERY_AUTH_MODE=none
DISCOVERY_BEARER_ACTOR=agent-discovery-token
# PUBLIC_READ_BEARER_TOKEN, PROPOSAL_BEARER_TOKEN, and
# DISCOVERY_BEARER_TOKEN belong in .env.secrets when their modes are active.
AGENT_SESSION_ENABLED=true
AGENT_SESSION_TTL_SECONDS=10800
AGENT_SESSION_CODE_LENGTH=8
AGENT_SESSION_CODE_CHARSET=ABCDEFGHJKLMNPQRSTUVWXYZ23456789
AGENT_SESSION_MAX_ACTIVE=10
AGENT_SESSION_AUTH_RATE_LIMIT_WINDOW_MS=60000
AGENT_SESSION_AUTH_RATE_LIMIT_MAX_FAILURES=30
AGENT_SESSION_AUTH_RATE_LIMIT_MAX_BUCKETS=10000

## Optional Authentik/OIDC configuration
# These values remain inactive while ADMIN_AUTH_MODE=simple and all agent areas
# use none/bearer. See .env.example.authentik for a deployment profile.
OIDC_PROPOSAL_ACCESS=all_authenticated_users
OIDC_PROPOSAL_GROUPS=managedskillhub-submitters
OIDC_PUBLIC_READ_ACCESS=all_authenticated_users
OIDC_PUBLIC_READ_GROUPS=managedskillhub-readers
OIDC_AGENT_ISSUER=
OIDC_AGENT_CLIENT_ID=
OIDC_AGENT_BASE_SCOPES=openid,profile,email
OIDC_DISCOVERY_SCOPE=managedskillhub:discovery
OIDC_PUBLIC_READ_SCOPE=managedskillhub:skills:read
OIDC_PROPOSAL_SCOPE=managedskillhub:proposals
OIDC_ADMIN_ISSUER=
OIDC_ADMIN_CLIENT_ID=
OIDC_ADMIN_REDIRECT_URI=
OIDC_ADMIN_SCOPES=openid,profile,email
OIDC_HUMAN_CLAIM=managedskillhub_human
OIDC_LOGIN_TRANSACTION_TTL_SECONDS=600
OIDC_CLOCK_TOLERANCE_SECONDS=30
OIDC_JWKS_CACHE_TTL_SECONDS=3600
OIDC_HTTP_TIMEOUT_MS=5000
OIDC_MAX_TOKEN_BYTES=16384
OIDC_MAX_GROUPS=100
OIDC_ACCESS_TOKEN_VALIDATION_MODE=jwt_profile
OIDC_INTROSPECTION_CLIENT_ID=
OIDC_ADMIN_SUBJECTS=
OIDC_ADMIN_GROUPS=managedskillhub-admins
OIDC_REVIEWER_GROUPS=managedskillhub-reviewers
OIDC_PUBLISHER_GROUPS=managedskillhub-publishers
# OIDC_ADMIN_CLIENT_SECRET and OIDC_INTROSPECTION_CLIENT_SECRET belong in
# .env.secrets when their corresponding modes are active.

## Providers & Judger
# Publicly documented values: noop, vercel-ai-sdk.
# Set a custom value to plug a custom judger adapter.
JUDGER_PROVIDER=noop

# Optional. Required when JUDGER_PROVIDER is not a built-in backend.
# Example: ./apps/api/src/adapters/llm/custom.judger.ts
JUDGER_ADAPTER_PATH=
PUBLISH_JUDGEMENT_POLICY=required

VERCEL_AI_SDK_MODEL=openai:gpt-4.1
VERCEL_AI_SDK_TIMEOUT_MS=30000
VERCEL_AI_SDK_MAX_TEXT_CHARS=12000
VERCEL_AI_SDK_MAX_RETRIES=0

## Data providers
CATALOG_PROVIDER=sqlite
SEARCH_PROVIDER=sqlite
# Physical storage for managed skill/proposal content. Supported: filesystem, database.
# database follows CATALOG_PROVIDER and supports SQLite or MySQL content storage.
CONTENT_STORAGE_PROVIDER=filesystem

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=managed_skill_hub
MYSQL_USER=managed_skill_hub
MYSQL_SSL_MODE=preferred
MYSQL_CONNECT_TIMEOUT_MS=10000
MYSQL_QUERY_TIMEOUT_MS=30000

## Proposal guardrails
PROPOSAL_MAX_FILES=30
PROPOSAL_MAX_FILE_SIZE_BYTES=10485760
PROPOSAL_DISALLOWED_PATHS=node_modules/,.venv/,venv/,vendor/,dist-packages/,site-packages/
PROPOSAL_RATE_LIMIT_WINDOW_MS=60000
PROPOSAL_RATE_LIMIT_MAX_REQUESTS=120
PROPOSAL_RATE_LIMIT_MAX_BUCKETS=10000
AUTO_PUBLISH_ON_GREEN=false
AUTO_APPROVE_WITHOUT_JUDGER=false
AUTO_PUBLISH_EXCLUDED_CATEGORIES=security,automation,filesystem,network
# Similarity score threshold (0-1) above which auto-publish requires a human reviewer.
AUTO_PUBLISH_SIMILARITY_THRESHOLD=0.5

## Frontend
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3041
# Use preview after build: FRONTEND_START_MODE=preview
FRONTEND_START_MODE=dev
VITE_API_BASE_URL=http://localhost:3040
# Set to false to disable proxying and call VITE_API_BASE_URL directly.
VITE_USE_API_PROXY=true
