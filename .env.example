# managed-skill-hub root environment example
# Copy to .env and fill in real values.

# In local dev mode:
# - DATA_DIR is ./data relative to repository root.
# - API/Frontend are served on localhost:3040 / localhost:3041.
# For production, prefer absolute paths.
NODE_ENV=development
DATA_DIR=./data

## API
API_HOST=127.0.0.1
API_PORT=3040
# Comma-separated proxy IPs/CIDRs whose forwarded client IP headers are trusted.
# Keep empty for direct API access. For local nginx, use 127.0.0.1,::1.
API_TRUSTED_PROXIES=
REGISTRY_ID=local
REGISTRY_NAME="ManagedSkillHub Local"
PUBLIC_API_BASE_URL=http://localhost:3040
# Optional API prefix in single-host deployments, e.g. /api.
API_PREFIX=
# Comma-separated browser origins allowed to call the API with credentials.
CORS_ALLOWED_ORIGINS=http://localhost:3041,http://127.0.0.1:3041

## Admin
ADMIN_USER=admin
# Prefer ADMIN_PASSWORD only for local/dev-like setups.
ADMIN_PASSWORD=admin
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-in-production
SESSION_TTL_SECONDS=86400
# Checks Origin/Referer for authenticated admin mutations when present.
ADMIN_CSRF_ORIGIN_CHECK=true

## Agent API auth
# Supported modes: none, bearer. Defaults keep local development open.
PUBLIC_READ_AUTH_MODE=none
PUBLIC_READ_BEARER_TOKEN=
PUBLIC_READ_BEARER_ACTOR=agent-read-token
PROPOSAL_AUTH_MODE=none
PROPOSAL_BEARER_TOKEN=
PROPOSAL_BEARER_ACTOR=agent-proposal-token
# Production requires PROPOSAL_AUTH_MODE=bearer unless this is explicitly true.
ALLOW_OPEN_PROPOSALS_IN_PRODUCTION=false
DISCOVERY_AUTH_MODE=none
DISCOVERY_BEARER_TOKEN=
DISCOVERY_BEARER_ACTOR=agent-discovery-token

## Providers & Judger
# Publicly documented values: noop, vercel-ai-sdk.
# Set a custom value to plug a custom judger adapter.
JUDGER_PROVIDER=noop

# Optional. Required when JUDGER_PROVIDER is not a built-in backend.
# Example: ./apps/api/src/adapters/llm/custom.judger.ts
JUDGER_ADAPTER_PATH=

VERCEL_AI_SDK_MODEL=openai:gpt-4.1
OPENAI_API_KEY=
VERCEL_AI_SDK_TIMEOUT_MS=30000
VERCEL_AI_SDK_MAX_TEXT_CHARS=12000
VERCEL_AI_SDK_MAX_RETRIES=0

## Data providers
CATALOG_PROVIDER=sqlite
SEARCH_PROVIDER=sqlite
# Physical storage for managed skill/proposal content. Supported: filesystem, database.
# database follows CATALOG_PROVIDER and supports SQLite or MySQL content storage.
CONTENT_STORAGE_PROVIDER=filesystem

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=managed_skill_hub
MYSQL_USER=managed_skill_hub
MYSQL_PASSWORD=
MYSQL_SSL_MODE=preferred
MYSQL_CONNECT_TIMEOUT_MS=10000
MYSQL_QUERY_TIMEOUT_MS=30000

## Proposal guardrails
PROPOSAL_MAX_FILES=30
PROPOSAL_MAX_FILE_SIZE_BYTES=10485760
PROPOSAL_DISALLOWED_PATHS=node_modules/,.venv/,venv/,vendor/,dist-packages/,site-packages/
PROPOSAL_RATE_LIMIT_WINDOW_MS=60000
PROPOSAL_RATE_LIMIT_MAX_REQUESTS=120
PROPOSAL_RATE_LIMIT_MAX_BUCKETS=10000
AUTO_PUBLISH_ON_GREEN=false
AUTO_APPROVE_WITHOUT_JUDGER=false
AUTO_PUBLISH_EXCLUDED_CATEGORIES=security,automation,filesystem,network

## Frontend
FRONTEND_PORT=3041
VITE_API_BASE_URL=http://localhost:3040
# Set to false to disable proxying and call VITE_API_BASE_URL directly.
VITE_USE_API_PROXY=true
