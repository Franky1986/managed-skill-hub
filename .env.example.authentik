# ManagedSkillHub authentik/OIDC target profile
#
# IMPORTANT: ADR-015 is accepted, but the current runtime does not yet implement
# OIDC modes. Do not deploy this file until the ADR-015 implementation gate is
# complete. Current startup rejects PUBLIC_READ_AUTH_MODE=oidc and
# PROPOSAL_AUTH_MODE=oidc.

NODE_ENV=production
DATA_DIR=/path/to/managed-skill-hub/data

## API
API_HOST=127.0.0.1
API_PORT=3040
API_TRUSTED_PROXIES=127.0.0.1,::1
REGISTRY_ID=company-authentik
REGISTRY_NAME="Company ManagedSkillHub"
PUBLIC_API_BASE_URL=https://skills.example.com/api
API_PREFIX=/api
CORS_ALLOWED_ORIGINS=https://skills.example.com

## Admin authentication
ADMIN_AUTH_MODE=oidc
# ManagedSkillHub still needs an independent strong secret for its own session
# integrity. This is not an authentik client secret.
JWT_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_SECONDS=28800
ADMIN_CSRF_ORIGIN_CHECK=true
# Local username/password settings are intentionally absent in OIDC mode.

## Independently configurable API areas
# Target modes after ADR-015 implementation: none, bearer, oidc.
DISCOVERY_AUTH_MODE=none
PUBLIC_READ_AUTH_MODE=none
PROPOSAL_AUTH_MODE=oidc
ALLOW_OPEN_PROPOSALS_IN_PRODUCTION=false

## Proposal and published-read OIDC policy
# Initial policy: every active interactive human accepted by the authentik
# application may submit proposals and read proposal status by known UUID.
OIDC_PROPOSAL_ACCESS=all_authenticated_users
OIDC_PROPOSAL_GROUPS=managedskillhub-submitters
# Used only when PUBLIC_READ_AUTH_MODE=oidc.
OIDC_PUBLIC_READ_ACCESS=all_authenticated_users
OIDC_PUBLIC_READ_GROUPS=managedskillhub-readers

## authentik agent Device Authorization provider
OIDC_AGENT_ISSUER=https://auth.example.com/application/o/managedskillhub-agent-device/
OIDC_AGENT_CLIENT_ID=managedskillhub-agent-device
OIDC_AGENT_BASE_SCOPES=openid,profile,email
OIDC_DISCOVERY_SCOPE=managedskillhub:discovery
OIDC_PUBLIC_READ_SCOPE=managedskillhub:skills:read
OIDC_PROPOSAL_SCOPE=managedskillhub:proposals

## authentik admin web provider
OIDC_ADMIN_ISSUER=https://auth.example.com/application/o/managedskillhub-admin-web/
OIDC_ADMIN_CLIENT_ID=managedskillhub-admin-web
# Supply this through the deployment secret manager, never from Git.
OIDC_ADMIN_CLIENT_SECRET=
OIDC_ADMIN_REDIRECT_URI=https://skills.example.com/api/admin/auth/oidc/callback
OIDC_ADMIN_SCOPES=openid,profile,email

## Stable privileged identities and groups
# Subject values are authentik user UUIDs because both providers use
# sub_mode=user_uuid. Do not use email addresses or usernames here.
OIDC_ADMIN_SUBJECTS=replace-with-initial-admin-user-uuid
OIDC_ADMIN_GROUPS=managedskillhub-admins
OIDC_REVIEWER_GROUPS=managedskillhub-reviewers
OIDC_PUBLISHER_GROUPS=managedskillhub-publishers

## Optional static bearer compatibility
# These values remain available when the corresponding area uses bearer mode.
PUBLIC_READ_BEARER_TOKEN=
PUBLIC_READ_BEARER_ACTOR=agent-read-token
PROPOSAL_BEARER_TOKEN=
PROPOSAL_BEARER_ACTOR=agent-proposal-token
DISCOVERY_BEARER_TOKEN=
DISCOVERY_BEARER_ACTOR=agent-discovery-token

## Judger
JUDGER_PROVIDER=noop
JUDGER_ADAPTER_PATH=
VERCEL_AI_SDK_MODEL=openai:gpt-4.1
OPENAI_API_KEY=
VERCEL_AI_SDK_TIMEOUT_MS=30000
VERCEL_AI_SDK_MAX_TEXT_CHARS=12000
VERCEL_AI_SDK_MAX_RETRIES=0

## Data providers
CATALOG_PROVIDER=sqlite
SEARCH_PROVIDER=sqlite
CONTENT_STORAGE_PROVIDER=filesystem
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=managed_skill_hub
MYSQL_USER=managed_skill_hub
MYSQL_PASSWORD=
MYSQL_SSL_MODE=verify_identity
MYSQL_CONNECT_TIMEOUT_MS=10000
MYSQL_QUERY_TIMEOUT_MS=30000

## Proposal guardrails
PROPOSAL_MAX_FILES=30
PROPOSAL_MAX_FILE_SIZE_BYTES=10485760
PROPOSAL_DISALLOWED_PATHS=node_modules/,.venv/,venv/,vendor/,dist-packages/,site-packages/
PROPOSAL_RATE_LIMIT_WINDOW_MS=60000
PROPOSAL_RATE_LIMIT_MAX_REQUESTS=120
PROPOSAL_RATE_LIMIT_MAX_BUCKETS=10000
AUTO_PUBLISH_ON_GREEN=false
AUTO_APPROVE_WITHOUT_JUDGER=false
AUTO_PUBLISH_EXCLUDED_CATEGORIES=security,automation,filesystem,network

## Frontend
FRONTEND_PORT=3041
VITE_API_BASE_URL=/api
VITE_USE_API_PROXY=false
