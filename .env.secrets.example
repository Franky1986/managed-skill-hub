# ManagedSkillHub secret environment example
# Copy to .env.secrets, set mode 0600, and fill only the secrets required by
# the active .env profile. Never commit .env.secrets.

## Simple admin authentication
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
JWT_SECRET=

## Static agent bearer compatibility
PUBLIC_READ_BEARER_TOKEN=
PROPOSAL_BEARER_TOKEN=
DISCOVERY_BEARER_TOKEN=

## Authentik confidential clients
OIDC_ADMIN_CLIENT_SECRET=
OIDC_INTROSPECTION_CLIENT_SECRET=

## Data and external providers
MYSQL_PASSWORD=
OPENAI_API_KEY=
