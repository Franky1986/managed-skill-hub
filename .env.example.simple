# ManagedSkillHub simple-auth profile
# This profile is supported by the current runtime and is intended for local
# development or explicitly isolated internal deployments.

NODE_ENV=development
DATA_DIR=./data

## API
API_HOST=127.0.0.1
API_PORT=3040
API_TRUSTED_PROXIES=
REGISTRY_ID=local-simple
REGISTRY_NAME="ManagedSkillHub Local Simple"
PUBLIC_API_BASE_URL=http://localhost:3040
API_PREFIX=
CORS_ALLOWED_ORIGINS=http://localhost:3041,http://127.0.0.1:3041

## Admin authentication
ADMIN_AUTH_MODE=simple
ADMIN_USER=admin
# ADMIN_PASSWORD, ADMIN_PASSWORD_HASH, and JWT_SECRET belong in .env.secrets.
SESSION_TTL_SECONDS=86400
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=300000
ADMIN_LOGIN_RATE_LIMIT_MAX_REQUESTS=10
ADMIN_LOGIN_RATE_LIMIT_MAX_BUCKETS=10000
ADMIN_CSRF_ORIGIN_CHECK=true
ADMIN_UI_BASE_PATH=/frontend/admin

## Agent API authentication
# Supported modes per area: none, bearer, oidc. This simple profile uses no OIDC.
PUBLIC_READ_AUTH_MODE=none
PUBLIC_READ_BEARER_ACTOR=agent-read-token
PROPOSAL_AUTH_MODE=none
PROPOSAL_BEARER_ACTOR=agent-proposal-token
ALLOW_OPEN_PROPOSALS_IN_PRODUCTION=false
DISCOVERY_AUTH_MODE=none
DISCOVERY_BEARER_ACTOR=agent-discovery-token

## Judger
JUDGER_PROVIDER=noop
JUDGER_ADAPTER_PATH=
VERCEL_AI_SDK_MODEL=openai:gpt-4.1
VERCEL_AI_SDK_TIMEOUT_MS=30000
VERCEL_AI_SDK_MAX_TEXT_CHARS=12000
VERCEL_AI_SDK_MAX_RETRIES=0

## Data providers
CATALOG_PROVIDER=sqlite
SEARCH_PROVIDER=sqlite
CONTENT_STORAGE_PROVIDER=filesystem
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=managed_skill_hub
MYSQL_USER=managed_skill_hub
MYSQL_SSL_MODE=preferred
MYSQL_CONNECT_TIMEOUT_MS=10000
MYSQL_QUERY_TIMEOUT_MS=30000

## Proposal guardrails
PROPOSAL_MAX_FILES=30
PROPOSAL_MAX_FILE_SIZE_BYTES=10485760
PROPOSAL_DISALLOWED_PATHS=node_modules/,.venv/,venv/,vendor/,dist-packages/,site-packages/
PROPOSAL_RATE_LIMIT_WINDOW_MS=60000
PROPOSAL_RATE_LIMIT_MAX_REQUESTS=120
PROPOSAL_RATE_LIMIT_MAX_BUCKETS=10000
AUTO_PUBLISH_ON_GREEN=false
AUTO_APPROVE_WITHOUT_JUDGER=false
AUTO_PUBLISH_EXCLUDED_CATEGORIES=security,automation,filesystem,network

## Frontend
FRONTEND_PORT=3041
VITE_API_BASE_URL=http://localhost:3040
VITE_USE_API_PROXY=true
