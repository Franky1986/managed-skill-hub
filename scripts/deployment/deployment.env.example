# Copy this file to deployment.env beside the installed service.sh.
# It contains no secrets.

MSH_SOURCE_DIR=src
MSH_SECRETS_FILE=.env.secrets
MSH_START_SCRIPT=src/scripts/deployment/install_and_start.sh
MSH_RUNTIME_SCRIPT=src/scripts/deployment/restart-server.sh
MSH_LOG_FILE=src/.tmp/server.log
MSH_API_HEALTH_URL=http://127.0.0.1:3040/api/health/ready
MSH_FRONTEND_HEALTH_URL=http://127.0.0.1:3041/frontend/
